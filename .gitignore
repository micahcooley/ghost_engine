# Ghost Engine .gitignore

# Zig build artifacts
.zig-cache/
.ghost_zig_cache/
**/.ghost_zig_global_cache/
**/.ghost_zig_local_cache/
**/.zig-cache/
**/zig-out/
zig-out/
cimport.zig

# Platform-specific build outputs
**/bin/*.exe
**/bin/*.dll
**/bin/*.pdb
**/bin/*.so
**/bin/*.dylib
**/plugins/*.dll
**/plugins/*.pdb
**/plugins/*.sigil
**/plugins/*.lib
**/plugins/*.exp

# General compiled artifacts
*.o
*.obj
*.spv
*.pdb
*.exe
*.dll

# Model state / weights (regeneratable via ohl_trainer)
*.bin

# Local development toolchain (sandboxed Zig/Vulkan)
.toolchain/

# Large training datasets (too large for GitHub LFS free tier)
/corpus/**
!/corpus/.gitkeep
**/corpus/wikitext_train.txt

# Transient telemetry and local config
trainer.log
ghost_config.json
**/web/node_modules/

# Ghost runtime/test state is generated by shard-local commands.
/state/test/
/platforms/*/*/state/

# Benchmark policy: only the canonical latest Linux reports are versioned.
/benchmarks/ghost_serious_workflows/results/*
!/benchmarks/ghost_serious_workflows/results/latest-linux.json
!/benchmarks/ghost_serious_workflows/results/latest-linux.md

# Verification shim state is intentionally transient.
/benchmarks/ghost_serious_workflows/shims/**/build_fail_once.stamp

# Root hygiene: no transient artifacts in the repository root
/*.log
/*.json
/*.out
/*.exe
/*.pdb
/*.obj

# Artifact sinks stay local-only
/logs/*
!/logs/.gitkeep
/scratch/*.log
/scratch/*.json
/scratch/*.out
/scratch/*.exe
/scratch/*.pdb
/scratch/*.obj
/scratch/*.csv
/scratch/*.err
/scratch/*stdout.txt
/scratch/*stderr.txt

# Explicit config/state exceptions
!/build.zig.zon
!/.vscode/settings.json
